# social-auto-upload 环境变量配置
# 复制此文件为 .env 并按需修改

# ── 后端 (web_runner.py) ──────────────────────────────────────────

# CORS 允许的来源（逗号分隔）
# 不设置则 CORS 关闭，跨域请求会被浏览器拦截
# SAU_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# OpenRouter API Key（用于 AI 内容生成）
# 也可在 Web UI 的 AI 侧边栏中配置
# OPENROUTER_API_KEY=

# 上传文件临时目录（默认 .sau_uploads/）
# SAU_UPLOADS_DIR=.sau_uploads

# ── 前端 (sau_web/frontend) ──────────────────────────────────────

# 后端 API 地址（开发模式默认走 Vite 代理，无需设置）
# 生产环境如需指定后端地址，取消注释并填写
# VITE_API_BASE_URL=http://localhost:6001
